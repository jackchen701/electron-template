{
  "name": "electron-template",
  "version": "1.0.0",
  "productName": "ElectronTemplate",
  "description": "Electron + Vue 3 + Vite + Element Plus template.",
  "author": "",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "dist-electron/main/index.js",
  "debug": {
    "env": {
      "VITE_DEV_SERVER_URL": "http://127.0.0.1:3344/"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && electron-builder",
    "build:win": "vue-tsc --noEmit && vite build && electron-builder --win",
    "build:mac": "vue-tsc --noEmit && vite build && electron-builder --mac",
    "build:linux": "vue-tsc --noEmit && vite build && electron-builder --linux",
    "tar:win": "node scripts/tar.mjs win",
    "tar:mac": "node scripts/tar.mjs mac",
    "tar:linux": "node scripts/tar.mjs linux",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{ts,vue}\" \"electron/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.{ts,vue}\" \"electron/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,css}\" \"electron/**/*.ts\""
  },
  "devDependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@vitejs/plugin-vue": "^5.0.4",
    "electron": "^29.1.1",
    "electron-builder": "^24.13.3",
    "element-plus": "^2.7.5",
    "less": "^4.2.0",
    "pinia": "^2.2.2",
    "typescript": "^5.4.2",
    "vite": "^5.1.5",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vue": "^3.4.21",
    "vue-router": "^4.3.3",
    "vue-tsc": "^2.0.6"
  },
  "dependencies": {
    "electron-store": "^10.0.0"
  }
}
